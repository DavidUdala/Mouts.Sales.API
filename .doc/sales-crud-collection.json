              "raw": "{{baseUrl}}/api/sales?_order=totalAmount desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales"],
              "query": [{ "key": "_order", "value": "totalAmount desc" }]
            }
          }
        },

        {
          "name": "5.4 Combined - filter + pagination + ordering",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Combined query is valid', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  pm.expect(body.currentPage).to.equal(1);",
                  "  console.log('Items:', body.data.length, '| Total:', body.totalCount);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sales?customerName=testuser&isCancelled=false&_page=1&_size=5&_order=saleDate desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales"],
              "query": [
                { "key": "customerName", "value": "testuser" },
