              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"id\": \"{{saleId}}\",\n  \"item\": {\n    \"id\": \"{{itemId}}\",\n    \"quantity\": 5,\n    \"unitPrice\": 9.90\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sales",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales"]
            },
            "description": "Updates the item from request 1.1.\nqty 5 + unitPrice 9.90 matches the Swagger example values.\nqty 5 triggers the 10% discount rule."
          }
        },

        {
          "name": "6.2 Update Sale - NOT FOUND",
