    {
      "name": "1. Create Sale",
      "item": [

        {
          "name": "1.1 Create Sale - No Discount (qty 3)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('No discount applied and variables saved', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.be.true;",
                  "  const data = body.data;",
                  "  pm.expect(data.items[0].discount).to.equal(0);",
                  "  pm.collectionVariables.set('saleId', data.id);",
                  "  pm.collectionVariables.set('itemId', data.items[0].id);",
                  "  pm.collectionVariables.set('saleNumber', data.saleNumber);",
                  "  console.log('saleId:', data.id);",
                  "  console.log('itemId:', data.items[0].id);",
                  "  console.log('saleNumber:', data.saleNumber);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"branchId\": \"11111111-1111-1111-1111-111111111111\",\n  \"items\": [\n    {\n      \"productId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n      \"quantity\": 3,\n      \"unitPrice\": 8.90\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sales",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales"]
            },
            "description": "Branch North + Skol 350ml + qty 3 → 0% discount\nExpected: discount = 0, totalAmount = 3 × 8.90 = 26.70\nSaves saleId, itemId and saleNumber for subsequent requests."
          }
        },

        {
          "name": "1.2 Create Sale - 10% Discount (qty 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
