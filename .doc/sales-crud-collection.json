                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Item is cancelled', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data.isCancelled).to.be.true;",
                  "  console.log('Cancelled itemId:', data.itemId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sales/{{saleId}}/items/{{itemId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales", "{{saleId}}", "items", "{{itemId}}", "cancel"]
            },
            "description": "Cancels the item from request 1.1 individually without cancelling the whole sale."
          }
        },

        {
          "name": "7.2 Cancel Sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "console.log('Cancelled sale response:', JSON.stringify(pm.response.json()));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sales/{{saleId}}/Cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales", "{{saleId}}", "Cancel"]
            },
            "description": "Cancels the entire sale from request 1.1."
          }
        },

        {
          "name": "7.3 Verify cancellation - isCancelled = true",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Returns cancelled sales', () => {",
                  "  const body = pm.response.json();",
                  "  body.data.forEach(s => pm.expect(s.isCancelled).to.be.true);",
                  "  pm.expect(body.data.length).to.be.greaterThan(0);",
                  "  console.log('Cancelled sales found:', body.data.length);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sales?isCancelled=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales"],
              "query": [{ "key": "isCancelled", "value": "true" }]
