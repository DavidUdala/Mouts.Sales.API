                  "  const item = pm.response.json().data.items[0];",
                  "  pm.expect(item.discount).to.equal(10);",
                  "  pm.expect(parseFloat(item.totalAmount.toFixed(2))).to.be.closeTo(5 * 8.90 * 0.90, 0.01);",
                  "  console.log('totalAmount:', item.totalAmount);",
                  "});"
                ]
